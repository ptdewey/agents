{
  "title": "Coding agents — cost & token usage",
  "uid": "coding-agents-cost",
  "tags": ["pi", "claude-code", "opencode", "cost"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "graphTooltip": 1,
  "editable": true,
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 2,
        "query": "label_values({__name__=~\"pi_tokens_total|claude_code_token_usage_tokens_total|opencode_tokens_total\"}, model)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row", "id": 100, "title": "Headlines",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false, "panels": []
    },
    {
      "id": 1, "type": "stat", "title": "Cost — last 24h (all sources)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "(sum(increase(pi_cost_usd_total{type=\"total\",model=~\"$model\"}[24h])) or on() vector(0)) + (sum(increase(claude_code_cost_usage_USD_total{model=~\"$model\"}[24h])) or on() vector(0)) + (sum(increase(opencode_cost_usd_total{model=~\"$model\"}[24h])) or on() vector(0))" }
      ]
    },
    {
      "id": 2, "type": "stat", "title": "Cost — last 1h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "(sum(increase(pi_cost_usd_total{type=\"total\",model=~\"$model\"}[1h])) or on() vector(0)) + (sum(increase(claude_code_cost_usage_USD_total{model=~\"$model\"}[1h])) or on() vector(0)) + (sum(increase(opencode_cost_usd_total{model=~\"$model\"}[1h])) or on() vector(0))" }
      ]
    },
    {
      "id": 3, "type": "stat", "title": "Tokens — last 24h (input+output)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "(sum(increase(pi_tokens_total{type=~\"input|output\",model=~\"$model\"}[24h])) or on() vector(0)) + (sum(increase(claude_code_token_usage_tokens_total{type=~\"input|output\",model=~\"$model\"}[24h])) or on() vector(0)) + (sum(increase(opencode_tokens_total{type=~\"input|output\",model=~\"$model\"}[24h])) or on() vector(0))" }
      ]
    },
    {
      "id": 4, "type": "stat", "title": "Cache-read tokens — last 24h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "(sum(increase(pi_tokens_total{type=\"cache_read\",model=~\"$model\"}[24h])) or on() vector(0)) + (sum(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\",model=~\"$model\"}[24h])) or on() vector(0)) + (sum(increase(opencode_tokens_total{type=~\"cache_read|cacheRead\",model=~\"$model\"}[24h])) or on() vector(0))" }
      ]
    },

    {
      "type": "row", "id": 200, "title": "Cost",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false, "panels": []
    },
    {
      "id": 10, "type": "timeseries", "title": "Cost rate by source ($/hour)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "pi",     "expr": "sum by (job) (rate(pi_cost_usd_total{type=\"total\",model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "{{job}}" },
        { "refId": "claude", "expr": "sum by (job) (rate(claude_code_cost_usage_USD_total{model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "{{job}}" },
        { "refId": "open",   "expr": "sum by (job) (rate(opencode_cost_usd_total{model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Cost rate by model ($/hour)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "pi",     "expr": "sum by (model) (rate(pi_cost_usd_total{type=\"total\",model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "pi/{{model}}" },
        { "refId": "claude", "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total{model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "claude/{{model}}" },
        { "refId": "open",   "expr": "sum by (model) (rate(opencode_cost_usd_total{model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "open/{{model}}" }
      ]
    },

    {
      "type": "row", "id": 300, "title": "Tokens",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false, "panels": []
    },
    {
      "id": 20, "type": "timeseries", "title": "Token rate by source & type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "pi",     "expr": "sum by (job, type) (rate(pi_tokens_total{type!=\"total\",model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{job}} / {{type}}" },
        { "refId": "claude", "expr": "sum by (job, type) (rate(claude_code_token_usage_tokens_total{model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{job}} / {{type}}" },
        { "refId": "open",   "expr": "sum by (job, type) (rate(opencode_tokens_total{type!=\"total\",model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{job}} / {{type}}" }
      ]
    },
    {
      "id": 21, "type": "timeseries", "title": "Output tokens / hour by model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "pi",     "expr": "sum by (model) (rate(pi_tokens_total{type=\"output\",model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "pi/{{model}}" },
        { "refId": "claude", "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{type=\"output\",model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "claude/{{model}}" },
        { "refId": "open",   "expr": "sum by (model) (rate(opencode_tokens_total{type=\"output\",model=~\"$model\"}[$__rate_interval])) * 3600", "legendFormat": "open/{{model}}" }
      ]
    },

    {
      "type": "row", "id": 400, "title": "Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false, "panels": []
    },
    {
      "id": 30, "type": "table", "title": "Cost by source & model — last 24h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "custom": { "align": "auto" } } },
      "options": { "showHeader": true },
      "transformations": [
        { "id": "merge" },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Cost (24h)" } } }
      ],
      "targets": [
        { "refId": "pi",     "expr": "sum by (job, model) (increase(pi_cost_usd_total{type=\"total\",model=~\"$model\"}[24h]))", "instant": true, "format": "table" },
        { "refId": "claude", "expr": "sum by (job, model) (increase(claude_code_cost_usage_USD_total{model=~\"$model\"}[24h]))", "instant": true, "format": "table" },
        { "refId": "open",   "expr": "sum by (job, model) (increase(opencode_cost_usd_total{model=~\"$model\"}[24h]))", "instant": true, "format": "table" }
      ]
    },
    {
      "id": 31, "type": "table", "title": "Tokens by source & type — last 24h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "align": "auto" } } },
      "options": { "showHeader": true },
      "transformations": [
        { "id": "merge" },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Tokens (24h)" } } }
      ],
      "targets": [
        { "refId": "pi",     "expr": "sum by (job, type) (increase(pi_tokens_total{type!=\"total\",model=~\"$model\"}[24h]))", "instant": true, "format": "table" },
        { "refId": "claude", "expr": "sum by (job, type) (increase(claude_code_token_usage_tokens_total{model=~\"$model\"}[24h]))", "instant": true, "format": "table" },
        { "refId": "open",   "expr": "sum by (job, type) (increase(opencode_tokens_total{type!=\"total\",model=~\"$model\"}[24h]))", "instant": true, "format": "table" }
      ]
    }
  ]
}
